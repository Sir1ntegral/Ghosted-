# Normalize line endings — text files stored as LF in the repo, so diffs stop
# churning between LF and CRLF across machines. Windows working copies may still be
# CRLF locally; git normalizes on commit.
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.txt   text eol=lf
*.spec  text eol=lf
*.iss   text eol=lf

# Windows-native scripts keep CRLF (some tooling expects it)
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binaries — never touch
*.ico   binary
*.png   binary
*.jpg   binary
*.exe   binary
*.dll   binary
*.pyd   binary
*.zip   binary
